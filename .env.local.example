# Google Sheets koppeling
# Kopieer dit bestand naar .env.local en vul de waarden in.

# Service-account e-mailadres (uit het JSON key-bestand: "client_email").
GOOGLE_CLIENT_EMAIL=osos-service@your-project.iam.gserviceaccount.com

# Service-account private key (uit het JSON key-bestand: "private_key").
# Bewaar de \n-tekens letterlijk en zet de hele key tussen dubbele quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...AESCBKg...\n-----END PRIVATE KEY-----\n"

# Spreadsheet-ID uit de URL van het Google Sheet:
# https://docs.google.com/spreadsheets/d/<DIT_DEEL>/edit
GOOGLE_SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789
